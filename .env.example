# Server-only — Unsplash photo search (lib/unsplash.ts). Never expose to the client.
UNSPLASH_ACCESS_KEY=

# Public — required for canonical URLs, sitemap.xml, robots.txt, and OpenGraph tags.
NEXT_PUBLIC_SITE_URL=https://managed-it.silverthaw.ca

# Public — Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# GA will not load until this is set to a real measurement ID.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
