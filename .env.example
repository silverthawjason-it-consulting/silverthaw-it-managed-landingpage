# Server-only — Unsplash photo search (lib/unsplash.ts). Never expose to the client.
UNSPLASH_ACCESS_KEY=

# Public — required for canonical URLs, sitemap.xml, robots.txt, and OpenGraph tags.
# Must be the real production domain before going live.
NEXT_PUBLIC_SITE_URL=https://www.silverthaw.com

# Public — Google Tag Manager container ID (format: GTM-XXXXXXX).
# GTM will not load until this is set to a real container ID.
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
